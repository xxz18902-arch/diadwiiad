-- ============================================
-- SCROLL TO BOTTOM FUNCTION (FIXED)
-- ============================================
local function updateCanvasSize()
    local contentHeight = chatLayout.AbsoluteContentSize.Y + 16 -- padding
    chatArea.CanvasSize = UDim2.new(0, 0, 0, contentHeight)
end

local function scrollToBottom(force)
    task.defer(function()
        updateCanvasSize()
        task.wait()
        local maxPos = chatArea.AbsoluteCanvasSize.Y - chatArea.AbsoluteWindowSize.Y
        if maxPos > 0 and (shouldAutoScroll or force) then
            chatArea.CanvasPosition = Vector2.new(0, maxPos)
        end
    end)
end

