local listeningForKey = nil

local function updateKeybind(btn, configKey, actionName)
    listeningForKey = btn
    btn.Text = "..."
    btn.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
    
    local connection
    connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if input.UserInputType == Enum.UserInputType.Keyboard then
            -- Unbind old action
            CAS:UnbindAction(actionName)
            
            -- Update config
            Config[configKey] = input.KeyCode
            
            -- Update UI
            btn.Text = input.KeyCode.Name
            btn.BackgroundColor3 = Color3.fromRGB(0, 140, 255)
            
            -- Rebind action with new key
            if actionName == "ToggleChatUI" then
                CAS:BindAction("ToggleChatUI", function(_, state)
                    if state == Enum.UserInputState.Begin then
                        if frame.Visible then
                            tween(frame, {Position = frame.Position + UDim2.new(0, 0, 0, 10), BackgroundTransparency = 1}, 0.2)
                            tween(shadow, {BackgroundTransparency = 1}, 0.2).Completed:Connect(function()
                                frame.Visible = false
                                shadow.Visible = false
                            end)
                        else
                            frame.Visible = true
                            shadow.Visible = true
                            frame.Position = frame.Position - UDim2.new(0, 0, 0, 10)
                            frame.BackgroundTransparency = 1
                            shadow.BackgroundTransparency = 1
                            tween(frame, {Position = frame.Position + UDim2.new(0, 0, 0, 10), BackgroundTransparency = 0}, 0.2)
                            tween(shadow, {BackgroundTransparency = 0.6}, 0.2)
                        end
                    end
                end, false, input.KeyCode)
            elseif actionName == "FocusChatBox" then
                CAS:BindAction("FocusChatBox", function(_, state)
                    if state == Enum.UserInputState.Begin then
                        if not frame.Visible then
                            frame.Visible = true
                            shadow.Visible = true
                            frame.BackgroundTransparency = 1
                            shadow.BackgroundTransparency = 1
                            tween(frame, {BackgroundTransparency = 0}, 0.2)
                            tween(shadow, {BackgroundTransparency = 0.6}, 0.2)
                        end
                        task.wait(0.1)
                        box:CaptureFocus()
                    end
                end, false, input.KeyCode)
            end
            
            listeningForKey = nil
            connection:Disconnect()
        end
    end)
end

