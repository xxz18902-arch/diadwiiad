        elseif capturingKey == "focus" then
            Config.FocusChatKey = input.KeyCode
            focusKeyBox.Text = keyName
            focusKeyBox.BackgroundColor3 = Joshua_COLORS.border
            CAS:UnbindAction("FocusChatBox")
            CAS:BindAction("FocusChatBox", function(_, state)
                if state == Enum.UserInputState.Begin then
                    frame.Visible = true
