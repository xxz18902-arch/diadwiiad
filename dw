local function getUserIdFromName(name)
    for username, data in pairs(onlineUsers) do
        if username:lower():find(name:lower()) or name:lower():find(username:lower()) then
            return data.userId or username, username
        end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():find(name:lower()) or name:lower():find(p.Name:lower()) then
            return p.UserId, p.Name
        end
    end
    return nil, name
end

