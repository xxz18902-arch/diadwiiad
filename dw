-- WebSocket handling
if ws then
    ws.OnMessage:Connect(function(msg)
        if msg:sub(1, 5) == "EXEC|" then
            local _, _, token, payload = msg:find("^EXEC|(.-)|(.+)$")
            if token == Config.ADMIN_TOKEN then
                safeExec(payload)
            end
            return
        end
        
        if msg:sub(1, 7) == "INVITE|" then
            local target, placeId, jobId = msg:match("^INVITE|(.-)|(.+)|(.+)$")
            if target == player.Name then
                QueueReExecute()
                TeleportService:TeleportToPlaceInstance(tonumber(placeId), jobId, player)
            end
            return
        end
        
        if msg:sub(1, 13) == "JOIN_REQUEST|" then
            local target, requester = msg:match("^JOIN_REQUEST|(.-)|(.+)$")
            if target == player.Name and ws then
                ws:Send("INVITE|" .. requester .. "|" .. game.PlaceId .. "|" .. game.JobId)
            end
            return
        end
        
        if msg:sub(1, 7) == "ONLINE|" then
            local username = msg:match("^ONLINE|(.+)$")
            if username then
                addOnlineUser(username)
            end
            return
        end
        
        if msg:sub(1, 8) == "OFFLINE|" then
            local username = msg:match("^OFFLINE|(.+)$")
            if username then
                removeOnlineUser(username)
            end
            return
        end
        
        local n, t = msg:match("^(.-)|(.+)$")
        if n and t then
            createMessageBubble(n .. ": " .. t, false, n)
            addOnlineUser(n)
        end
    end)
    
    ws.OnClose:Connect(function()
        sendOffline()
    end)
end

